---
import Base from '../layouts/Base.astro';
---

<Base title="404 — Quantum Proof" description="That page doesn't exist.">
  <section class="container-prose flex min-h-[60vh] flex-col items-center justify-center text-center py-20">
    <span class="font-mono text-6xl font-extrabold text-brand-700 dark:text-brand-400">404</span>
    <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 dark:text-white">
      Lost in superposition
    </h1>
    <p class="mt-3 max-w-md text-slate-600 dark:text-slate-400">
      That page collapsed to a state we can't observe. Try one of these instead.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a class="btn btn-primary" href="/">Home</a>
      <a class="btn btn-outline" href="/oathbreaker">Oathbreaker</a>
      <a class="btn btn-outline" href="/docs">Docs</a>
    </div>
  </section>
</Base>

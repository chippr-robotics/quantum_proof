---
import Base from '../layouts/Base.astro';
import StatCard from '../components/StatCard.astro';
import AttackCalculator from '../components/AttackCalculator.tsx';

const timeline = [
  { year: '2004', who: 'Proos & Zalka', body: '~6,000 logical qubits, trillions of gates' },
  { year: '2017', who: 'Roetteler et al.', body: '~2,500 logical qubits, billions of Toffoli gates' },
  { year: '2020', who: 'Häner et al.', body: '~2,300 logical qubits, further gate reductions' },
  { year: '2023a', who: 'Gouzien & Sangouard', body: '~2,000 logical qubits' },
  { year: '2023b', who: 'Litinski', body: '~2,500 qubits, ~200 M Toffoli, ~9 M physical (photonic)' },
  { year: '2026', who: 'Chevignard et al.', body: '~1,100 logical qubits but >100 B Toffoli' },
  {
    year: '2026',
    who: 'Google Quantum AI',
    body: '≤1,200 qubits & 90M gates (or ≤1,450 qubits & 70M). <500 K physical. ~10× spacetime improvement.',
    highlight: true,
  },
];
---

<Base
  title="The Threat — Quantum Proof"
  description="Why Shor's algorithm against ECDLP is the cryptographic event of the decade — and why the new resource estimates change the timeline."
>
  <div class="container-prose py-14">
    <span class="section-eyebrow">The threat</span>
    <h1 class="mt-3 max-w-3xl text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl dark:text-white">
      Shor's algorithm vs. elliptic curves — the timeline shifted
    </h1>
    <p class="mt-5 max-w-2xl text-lg leading-relaxed text-slate-700 dark:text-slate-300">
      Bitcoin, Ethereum, and most of the Web's PKI rest on the hardness of the
      <strong>Elliptic Curve Discrete Logarithm Problem</strong>: given <code>G</code> and
      <code>Q = [k]G</code>, recover <code>k</code>. A sufficiently large fault-tolerant quantum
      computer breaks ECDLP in polynomial time. The only remaining question has always been:
      <em>how big is "sufficiently large"?</em>
    </p>
  </div>

  <!-- Resource numbers -->
  <section class="bg-brand-50/60 py-14 dark:bg-slate-900/40">
    <div class="container-prose">
      <span class="section-eyebrow">Google Quantum AI · March 2026</span>
      <h2 class="section-title mt-3">Two variants, one devastating result</h2>
      <p class="section-desc">
        Babbush, Zalcman, Gidney et al. published two optimized circuits trading off qubit count
        against gate count. The numbers below are for full ECDLP over secp256k1.
      </p>

      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <StatCard value="≤1,200" label="Logical qubits (low-qubit)" hint="2,700K Toffoli per point-add" accent />
        <StatCard value="≤90 M" label="Toffoli gates (low-qubit)" hint="28 windowed point-adds at w=16" />
        <StatCard value="≤1,450" label="Logical qubits (low-gate)" hint="2,100K Toffoli per point-add" />
        <StatCard value="≤70 M" label="Toffoli gates (low-gate)" />
      </div>

      <div class="mt-10 grid gap-4 sm:grid-cols-3">
        <StatCard value="<500K" label="Physical qubits" hint="Surface code at 10⁻³ error rate" />
        <StatCard value="~23 min" label="Full attack runtime" hint="Reaction-limited at 10 µs control loop" />
        <StatCard value="~12 min" label="Primed attack" hint="Pre-computed lookup tables ready" />
      </div>

      <div class="mt-10 rounded-xl border border-slate-200 bg-white p-6 dark:border-slate-800 dark:bg-slate-900">
        <h3 class="text-base font-bold text-slate-900 dark:text-white">How point addition scales to full ECDLP</h3>
        <p class="mt-3 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
          The verifiable claim is the cost of <strong>elliptic-curve point addition</strong>. The full
          ECDLP cost follows from windowed scalar multiplication:
        </p>
        <p class="my-4 text-center font-mono text-base text-brand-800 dark:text-brand-200">
          ECDLP<sub>Toff</sub> = (PA<sub>Toff</sub> + 3 · 2<sup>w</sup>) · (2n/w − 4)
        </p>
        <p class="text-sm leading-relaxed text-slate-600 dark:text-slate-400">
          With <code>w=16</code> and <code>n=256</code>, the algorithm performs 28 windowed point
          additions — <code>(2,700,000 + 196,608) × 28 ≈ 81M</code> Toffoli gates on
          <code>1,175 + 16 = 1,191</code> logical qubits for the low-qubit variant.
        </p>
      </div>
    </div>
  </section>

  <!-- Attack timing -->
  <section class="bg-white py-14 dark:bg-slate-950">
    <div class="container-prose">
      <span class="section-eyebrow">Race conditions</span>
      <h2 class="section-title mt-3">When does the attack succeed?</h2>
      <p class="section-desc">
        For an on-chain spend, the attacker has from the moment a transaction reveals the public key
        until the next block confirms. Block times follow an exponential distribution.
      </p>

      <div class="mt-8 grid gap-8 lg:grid-cols-[1fr_auto]">
        <figure>
          <img
            src="/attack_timing.png"
            alt="Plot of classical confirmation race vs. quantum attack runtime"
            class="rounded-xl border border-slate-200 dark:border-slate-800"
            loading="lazy"
          />
          <figcaption class="mt-2 text-xs italic text-slate-500 dark:text-slate-400">
            Classical confirmation race vs. quantum attack runtime — see the notebook for
            derivation.
          </figcaption>
        </figure>

        <AttackCalculator client:visible />
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="bg-brand-50/60 py-14 dark:bg-slate-900/40">
    <div class="container-prose">
      <span class="section-eyebrow">Historical context</span>
      <h2 class="section-title mt-3">The shrinking cost of breaking ECDLP</h2>
      <p class="section-desc">
        Resource estimates have dropped two orders of magnitude in twenty years. <em>Attacks
        always get better.</em>
      </p>

      <ol class="mt-10 space-y-4 border-l-2 border-brand-200 pl-6 dark:border-brand-800">
        {timeline.map((t) => (
          <li
            class:list={[
              'relative reveal',
              t.highlight && 'rounded-xl border border-brand-300 bg-brand-100/60 p-4 dark:border-brand-700 dark:bg-brand-950/40',
            ]}
          >
            <span
              class:list={[
                'absolute -left-[33px] mt-1.5 inline-block h-3 w-3 rounded-full',
                t.highlight ? 'bg-brand-600 ring-4 ring-brand-200 dark:ring-brand-800' : 'bg-brand-400',
              ]}
              aria-hidden="true"
            ></span>
            <p class="font-mono text-xs uppercase tracking-wider text-brand-700 dark:text-brand-300">
              {t.year} · {t.who}
            </p>
            <p class:list={['mt-1', t.highlight ? 'text-base font-semibold text-slate-900 dark:text-white' : 'text-sm text-slate-700 dark:text-slate-300']}>
              {t.body}
            </p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-white py-16 dark:bg-slate-950">
    <div class="container-prose flex flex-wrap items-center justify-between gap-6">
      <div>
        <h2 class="section-title">Ready for the implementation?</h2>
        <p class="section-desc">
          Oathbreaker is our open-source analogue of the same algorithm — measurable, classically
          verifiable, and reproducible.
        </p>
      </div>
      <div class="flex flex-wrap gap-3">
        <a href="/oathbreaker" class="btn btn-primary">Tour Oathbreaker →</a>
        <a href="/results" class="btn btn-outline">See measured results</a>
      </div>
    </div>
  </section>
</Base>

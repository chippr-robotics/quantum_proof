---
import { getCollection } from 'astro:content';

interface Props {
  currentTitle?: string;
}
const { currentTitle } = Astro.props;

const docs = await getCollection('docs');
docs.sort((a, b) => a.data.order - b.data.order);

// Group by category, preserving first-seen order.
const grouped = new Map<string, typeof docs>();
for (const d of docs) {
  const cat = d.data.category;
  if (!grouped.has(cat)) grouped.set(cat, []);
  grouped.get(cat)!.push(d);
}
---

<aside class="hidden lg:block">
  <nav
    class="sticky top-20 max-h-[calc(100vh-6rem)] overflow-y-auto pr-2 text-sm"
    aria-label="Docs navigation"
  >
    <p class="mb-3 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">
      All docs
    </p>
    <ul class="space-y-5">
      {Array.from(grouped.entries()).map(([cat, list]) => (
        <li>
          <p class="mb-1 text-[0.7rem] font-bold uppercase tracking-wider text-brand-700 dark:text-brand-400">
            {cat}
          </p>
          <ul class="space-y-1">
            {list.map((d) => {
              const isCurrent = d.data.title === currentTitle;
              return (
                <li>
                  <a
                    href={`/docs/${d.slug}`}
                    aria-current={isCurrent ? 'page' : undefined}
                    class:list={[
                      'block rounded-md border-l-2 px-2 py-1 transition-colors',
                      isCurrent
                        ? 'border-brand-600 bg-brand-50 font-semibold text-brand-800 dark:bg-brand-900/30 dark:text-brand-200'
                        : 'border-transparent text-slate-600 hover:border-brand-300 hover:text-brand-800 dark:text-slate-400 dark:hover:text-brand-300',
                    ]}
                  >
                    {d.data.title}
                  </a>
                </li>
              );
            })}
          </ul>
        </li>
      ))}
    </ul>
  </nav>
</aside>

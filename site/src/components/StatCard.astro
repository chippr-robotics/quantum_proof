---
interface Props {
  value: string;
  label: string;
  hint?: string;
  accent?: boolean;
}
const { value, label, hint, accent = false } = Astro.props;
---

<div
  class:list={[
    'card card-hover reveal',
    accent && 'border-brand-300 bg-brand-50/40 dark:border-brand-700/60 dark:bg-brand-950/30',
  ]}
>
  <div class="font-mono text-3xl font-extrabold text-brand-700 dark:text-brand-300">{value}</div>
  <div class="mt-1 text-sm font-semibold text-slate-700 dark:text-slate-300">{label}</div>
  {hint && <div class="mt-2 text-xs text-slate-500 dark:text-slate-400">{hint}</div>}
</div>

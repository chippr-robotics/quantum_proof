---
import Base from './Base.astro';
import DocSidebar from '../components/DocSidebar.astro';

interface Props {
  title: string;
  description?: string;
  category?: string;
  sourceFile?: string;
}

const { title, description, category, sourceFile } = Astro.props;

const sourceUrl = sourceFile
  ? `https://github.com/chippr-robotics/quantum_proof/blob/main/${sourceFile}`
  : null;
---

<Base title={`${title} — Quantum Proof`} description={description}>
  <div class="container-prose pt-10 pb-20">
    <div class="mb-8">
      <a
        href="/docs"
        class="text-sm font-medium text-brand-700 hover:text-brand-800 dark:text-brand-400 dark:hover:text-brand-300"
      >
        ← All docs
      </a>
    </div>

    <div class="grid gap-10 lg:grid-cols-[1fr_220px]">
      <article>
        <header class="mb-8 border-b border-slate-200 pb-6 dark:border-slate-800">
          {category && <span class="section-eyebrow">{category}</span>}
          <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-slate-900 dark:text-white">
            {title}
          </h1>
          {description && (
            <p class="mt-3 text-lg leading-relaxed text-slate-600 dark:text-slate-400">
              {description}
            </p>
          )}
          {sourceUrl && (
            <p class="mt-4 text-xs text-slate-500 dark:text-slate-500">
              Source:{' '}
              <a href={sourceUrl} class="font-mono underline" target="_blank" rel="noopener">
                {sourceFile}
              </a>
            </p>
          )}
        </header>

        <div class="prose-doc">
          <slot />
        </div>
      </article>

      <DocSidebar currentTitle={title} />
    </div>
  </div>
</Base>
